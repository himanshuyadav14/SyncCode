# ─── Redis (required for code/chat persistence) ──────────────────────
# e.g. Upstash: rediss://default:YOUR_PASSWORD@YOUR_HOST:6379
REDIS_URL=

# ─── Server (custom Node server – not used when frontend is on Vercel only) ─
PORT=3000
HOSTNAME=localhost

# ─── Code execution (Piston API) ─────────────────────────────────────
# Full URL; self-hosted example: http://localhost:2000/api/v2/execute
PISTON_API_URL=

# ─── Zego Cloud – video/audio calls ────────────────────────────────────
# Get from https://console.zegocloud.com
NEXT_PUBLIC_ZEGO_APP_ID=
NEXT_PUBLIC_ZEGO_SERVER_SECRET=

# ─── SMTP – email invites ───────────────────────────────────────────
# Optional; if unset, invites are stored but no email is sent
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=SyncCode
SMTP_FROM_EMAIL=

# ─── Optional: Socket server URL (for split deployment) ──────────────
# If Next.js is on Vercel and Socket server runs elsewhere, set this to the Socket server URL.
# NEXT_PUBLIC_SOCKET_URL=https://your-socket-server.example.com
